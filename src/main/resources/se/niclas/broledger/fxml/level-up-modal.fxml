<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox styleClass="app-frame" minWidth="400" minHeight="200" maxHeight="600"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="se.niclas.broledger.ui.LevelUpModalController">

    <HBox fx:id="titleBar" styleClass="title-bar" alignment="CENTER_LEFT">
        <Label text="Level Up Detected" styleClass="title-bar-label"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="✕" styleClass="window-btn,window-btn-close" onAction="#close" focusTraversable="false"/>
    </HBox>

    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED">
        <VBox fx:id="eventsContainer" spacing="12">
            <padding><Insets top="16" right="20" bottom="8" left="20"/></padding>
        </VBox>
    </ScrollPane>

    <VBox>
        <padding><Insets top="8" right="20" bottom="16" left="20"/></padding>
        <HBox alignment="CENTER_RIGHT">
            <Button text="Close" onAction="#close" styleClass="fancy-btn"/>
        </HBox>
    </VBox>

</VBox>
