<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.animation.PauseTransition?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox styleClass="app-frame" minWidth="540" minHeight="340"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="se.niclas.broledger.ui.SetupController">

    <!-- Custom title bar -->
    <HBox fx:id="titleBar" styleClass="title-bar" alignment="CENTER_LEFT">
        <Label text="Game Art Setup" styleClass="title-bar-label"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="✕" styleClass="window-btn,window-btn-close" onAction="#skip" focusTraversable="false"/>
    </HBox>

    <!-- Content -->
    <VBox spacing="16" VBox.vgrow="ALWAYS">
        <padding><Insets top="20" right="24" bottom="24" left="24"/></padding>

        <Label text="No game-art directory is configured. Choose an option:"
               styleClass="stat-label" wrapText="true"/>

        <!-- Extract from game data -->
        <VBox spacing="10" styleClass="card-section">
            <Label text="Extract from game data" styleClass="section-header"/>
            <Label text="Point to data_001.dat in your Battle Brothers installation and choose an output folder."
                   styleClass="stat-label" wrapText="true"/>

            <HBox spacing="8" alignment="CENTER_LEFT">
                <Label text="data_001.dat:" styleClass="field-label" minWidth="110"/>
                <TextField fx:id="datPathField" styleClass="role-field"
                           promptText="Select data_001.dat…"
                           HBox.hgrow="ALWAYS" maxWidth="Infinity" editable="false"/>
                <Button text="Browse" onAction="#browseDat" styleClass="fancy-btn" minWidth="70"/>
            </HBox>

            <HBox spacing="8" alignment="CENTER_LEFT">
                <Label text="Output folder:" styleClass="field-label" minWidth="110"/>
                <TextField fx:id="outDirField" styleClass="role-field"
                           promptText="Output directory…"
                           HBox.hgrow="ALWAYS" maxWidth="Infinity" editable="false"/>
                <Button text="Browse" onAction="#browseOutDir" styleClass="fancy-btn" minWidth="70"/>
            </HBox>

            <ProgressBar fx:id="progressBar" maxWidth="Infinity" progress="0"
                         visible="false" managed="false"/>
            <Label fx:id="progressLabel" text="" styleClass="stat-label"
                   visible="false" managed="false" wrapText="true"/>

            <HBox alignment="CENTER_RIGHT">
                <Button fx:id="extractBtn" text="Extract" onAction="#startExtract"
                        styleClass="fancy-btn" disable="true"/>
            </HBox>
        </VBox>

        <Label text="— or —" styleClass="stat-label" maxWidth="Infinity"/>

        <!-- Select existing folder -->
        <Button text="Select existing game-art folder" onAction="#selectExisting"
                styleClass="fancy-btn" maxWidth="Infinity"/>

        <Region VBox.vgrow="ALWAYS"/>

        <HBox alignment="CENTER_RIGHT">
            <Button text="Skip for now" onAction="#skip" styleClass="fancy-btn"/>
        </HBox>
    </VBox>

</VBox>
